public class Curso {
    String clave;
    String nombre;
    String docente;
    int cupoMaximo;
    int inscritos;

    public Curso(String clave, String nombre, String docente, int cupoMaximo) {
        this.clave = clave;
        this.nombre = nombre;
        this.docente = docente;
        this.cupoMaximo = cupoMaximo;
        this.inscritos = 0;
    }
}
